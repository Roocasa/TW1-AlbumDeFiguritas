# Configuración de la base de datos MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=tallerwebi
MYSQL_USER=user
MYSQL_PASSWORD=user

# Variables de entorno para la conexión a la base de datos (usadas por la aplicación)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=tallerwebi
DB_USER=user
DB_PASSWORD=user 

# Variables de Mercado Pago usadas por la tienda
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_BASE_URL=http://localhost:8080/spring

# Token opcional para actualizar resultados del Prode desde football-data.org
FOOTBALL_DATA_TOKEN=
